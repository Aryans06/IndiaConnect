# --- Database (Postgres) ---
# Local dev: run `npx prisma dev` (Prisma's local Postgres) or use a free
# Prisma Postgres / Neon cloud DB via `npx create-db`, then paste the URL here.
DATABASE_URL="postgresql://user:password@localhost:5432/indiaconnect?schema=public"

# --- Gemini (Google AI Studio, free tier) --- Phase 1 + 5
GEMINI_API_KEY=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Clerk auth --- Phase 4
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SIGNING_SECRET=""
# Local dev without Clerk keys: sign in as a fixed mock user to test the
# account / profile / DigiLocker flows. Ignored once Clerk keys are set.
DEV_MOCK_AUTH="false"

# --- DigiLocker (OAuth, sandbox) --- Phase 4
DIGILOCKER_CLIENT_ID=""
DIGILOCKER_CLIENT_SECRET=""
DIGILOCKER_REDIRECT_URI="http://localhost:3000/api/digilocker/callback"
# Use the in-repo mock provider instead of real DigiLocker during local dev.
DIGILOCKER_USE_MOCK="true"

# --- Translation (scheme content into Indian languages) ---
# Provider is auto-selected: Bhashini if its keys are set, else Gemini, else the
# app simply shows English content. Force one with: bhashini | gemini | none
TRANSLATE_PROVIDER=""

# Bhashini is optional — India's official language stack, but its signup is
# gated. Gemini (key above) handles translation fine without a second account.
# Voice (speech in/out) needs NO keys at all — it uses the browser's Web Speech API.
BHASHINI_API_KEY=""
BHASHINI_USER_ID=""
